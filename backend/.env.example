# LLM Provider Configuration
# Supported format: groq/llama-3.3-70b-versatile, gemini/gemini-flash-latest, etc.
LLM_MODEL=gemini/gemini-flash-latest

# API Keys (Provide the keys for the selected model provider)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Job Aggregator Configuration
# Active subscription key on RapidAPI JSearch
RAPIDAPI_KEY=your_rapidapi_key_here

# Pacing config to reset Tokens-Per-Minute (TPM) limits on free tiers
# Set to 0 to disable sleep pacing if you are on a paid/unrestricted tier
RATE_LIMIT_DELAY_SECONDS=65
